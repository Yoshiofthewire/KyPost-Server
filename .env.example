OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODELS_HOST_DIR=./share/ollama/models

# Optional overrides
TUNING_FILE=/llama_lab/config/TUNING.md
TZ=America/New_York
# Public server URL used in the mobile pairing QR payload (for example https://my-domain.example)
SERVER_BASE_URL=
# Required for native mobile pairing token signing/validation
PAIRING_SECRET=

# Optional direct native push sender (backend -> FCM HTTP v1)
# Keep this server-side only; do not embed in mobile apps.
FCM_SERVICE_ACCOUNT_FILE=
# Optional override; if omitted we use project_id from service-account json.
FCM_PROJECT_ID=
# Optional override for OAuth token URL (defaults to token_uri from service-account json)
FCM_TOKEN_URL=
# Optional override for FCM v1 send URL (defaults to https://fcm.googleapis.com/v1/projects/<project>/messages:send)
FCM_SEND_URL=
